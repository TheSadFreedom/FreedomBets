{
  "name": "freedombets",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "prestart": "node scripts/generateEventsManifest.mjs && node scripts/generateTeamsManifest.mjs",
    "prebuild": "node scripts/generateEventsManifest.mjs && node scripts/generateTeamsManifest.mjs",
    "start": "concurrently -n api,web -c green,cyan \"npm run server\" \"npm run dev\"",
    "preview:app": "vite preview --host",
    "serve": "npm run build && concurrently -k -n api,web -c green,cyan \"npm run server\" \"npm run preview:app\"",
    "cloudpub": "concurrently -k -n app,tunnel -c green,magenta \"npm run serve\" \"wait-on -t 120000 http-get://127.0.0.1:8080 && clo publish http 8080 --name freedombets\"",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "server": "node server/index.mjs db.json",
    "migrate:pickems": "node scripts/migratePickemImages.mjs",
    "migrate:link-bets": "node scripts/linkBetsToMatches.mjs",
    "events:manifest": "node scripts/generateEventsManifest.mjs",
    "teams:manifest": "node scripts/generateTeamsManifest.mjs"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.6",
    "@mui/material": "^7.3.6",
    "axios": "^1.13.2",
    "cheerio": "^1.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "styled-components": "^6.1.19"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/styled-components": "^5.1.36",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "json-server": "^1.0.0-beta.3",
    "multer": "^2.1.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "wait-on": "^9.0.10"
  }
}
